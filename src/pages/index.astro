---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import Clients from "../components/Clients.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const lang = "es";
---

<Layout
  title="Suit Software - Soluciones de Software Modernas"
  description="Desarrollo web de alta calidad, aplicaciones móviles, diseño UI/UX y servicios de consultoría en la nube. Transforma tu negocio con soluciones de software modernas."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Services lang={lang} />
    <Clients lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
