---
import { t, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
---

<section id="contact" class="py-24 lg:py-32 bg-gradient-to-br from-white via-brand-50/20 to-white dark:from-surface-950 dark:via-brand-900/5 dark:to-surface-950 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-1/2 left-0 w-96 h-96 bg-brand-500/10 dark:bg-brand-600/10 rounded-full filter blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-brand-500/10 dark:bg-brand-500/5 rounded-full filter blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal-on-scroll">
      <span class="inline-flex items-center gap-2 px-4 py-2 text-xs font-bold tracking-wide uppercase rounded-full bg-brand-100 dark:bg-brand-900/30 text-brand-700 dark:text-brand-400 border border-brand-200 dark:border-brand-800 mb-4">
        {t(lang, "contact.label")}
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-black tracking-tight text-surface-900 dark:text-white text-balance font-sans">
        {t(lang, "contact.title")}
      </h2>
      <p class="mt-6 text-lg sm:text-xl text-surface-600 dark:text-surface-300 leading-relaxed">
        {t(lang, "contact.description")}
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-12 items-start">
      <!-- Contact Info (2 cols) -->
      <div class="lg:col-span-2 flex flex-col gap-8 reveal-on-scroll reveal-left">
        <div class="bg-gradient-to-br from-brand-50 to-white dark:from-surface-800 dark:to-surface-800/50 rounded-3xl p-8 border border-brand-100 dark:border-surface-700">
          <h3 class="text-2xl font-black text-surface-900 dark:text-white mb-4 font-sans">
            {t(lang, "contact.info.title")}
          </h3>
          <p class="text-surface-600 dark:text-surface-300 leading-relaxed">
            {t(lang, "contact.info.description")}
          </p>
        </div>

        <!-- Contact Methods -->
        <div class="flex flex-col gap-5">
          <a href="mailto:contact@suitsoftware.com" class="group flex items-center gap-4 p-4 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-2xl hover:border-brand-400 dark:hover:border-brand-600 hover:shadow-lg transition-all duration-200 cursor-pointer">
            <div class="w-14 h-14 bg-gradient-to-br from-brand-100 to-brand-50 dark:from-brand-900/40 dark:to-brand-800/40 rounded-xl flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-brand-600 dark:text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-bold text-surface-900 dark:text-white">{t(lang, "contact.email")}</div>
              <div class="text-sm text-brand-600 dark:text-brand-400 font-medium">contact@suitsoftware.com</div>
            </div>
          </a>

          <a href="tel:+593099571025" class="group flex items-center gap-4 p-4 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-2xl hover:border-brand-400 dark:hover:border-brand-600 hover:shadow-lg transition-all duration-200 cursor-pointer">
            <div class="w-14 h-14 bg-gradient-to-br from-brand-100 to-brand-50 dark:from-brand-900/40 dark:to-brand-800/40 rounded-xl flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-brand-600 dark:text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-bold text-surface-900 dark:text-white">{t(lang, "contact.phone")}</div>
              <div class="text-sm text-brand-600 dark:text-brand-400 font-medium">+593 099 571 0255</div>
            </div>
          </a>

          <div class="flex items-center gap-4 p-4 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-2xl">
            <div class="w-14 h-14 bg-gradient-to-br from-brand-100 to-brand-50 dark:from-brand-900/40 dark:to-brand-800/40 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-brand-600 dark:text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-bold text-surface-900 dark:text-white">{t(lang, "contact.office")}</div>
              <div class="text-sm text-surface-600 dark:text-surface-400">{t(lang, "contact.office.value")}</div>
            </div>
          </div>
        </div>

        <!-- Response Time -->
        <div class="bg-gradient-to-br from-brand-50 to-white dark:from-brand-900/20 dark:to-surface-800 border-2 border-brand-200 dark:border-brand-800/50 p-6 rounded-2xl">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 bg-brand-500 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h4 class="text-base font-black text-surface-900 dark:text-white mb-1 font-sans">
                {t(lang, "contact.response.title")}
              </h4>
              <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">
                {t(lang, "contact.response.description")}
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form (3 cols) -->
      <div class="lg:col-span-3 bg-white dark:bg-surface-800 border-2 border-surface-200 dark:border-surface-700 p-8 lg:p-10 rounded-3xl reveal-on-scroll reveal-right reveal-delay-1 shadow-xl shadow-surface-900/5 dark:shadow-none">
        <form id="contact-form" class="flex flex-col gap-5">
          <div class="grid md:grid-cols-2 gap-5">
            <div>
              <label for="first-name" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-2">
                {t(lang, "contact.form.firstName")} *
              </label>
              <input
                type="text"
                id="first-name"
                name="firstName"
                required
                class="w-full px-4 py-3 border border-surface-200 dark:border-surface-600 rounded-xl bg-surface-50 dark:bg-surface-900 text-surface-900 dark:text-white placeholder-surface-400 transition-colors text-sm"
                placeholder="John"
              />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-2">
                {t(lang, "contact.form.lastName")} *
              </label>
              <input
                type="text"
                id="last-name"
                name="lastName"
                required
                class="w-full px-4 py-3 border border-surface-200 dark:border-surface-600 rounded-xl bg-surface-50 dark:bg-surface-900 text-surface-900 dark:text-white placeholder-surface-400 transition-colors text-sm"
                placeholder="Doe"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-2">
              {t(lang, "contact.form.email")} *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-surface-200 dark:border-surface-600 rounded-xl bg-surface-50 dark:bg-surface-900 text-surface-900 dark:text-white placeholder-surface-400 transition-colors text-sm"
              placeholder="john@example.com"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-2">
              {t(lang, "contact.form.company")}
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full px-4 py-3 border border-surface-200 dark:border-surface-600 rounded-xl bg-surface-50 dark:bg-surface-900 text-surface-900 dark:text-white placeholder-surface-400 transition-colors text-sm"
              placeholder={lang === "en" ? "Your Company" : "Tu Empresa"}
            />
          </div>

          <div class="grid md:grid-cols-2 gap-5">
            <div>
              <label for="service" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-2">
                {t(lang, "contact.form.service")} *
              </label>
              <select
                id="service"
                name="service"
                required
                class="w-full px-4 py-3 border border-surface-200 dark:border-surface-600 rounded-xl bg-surface-50 dark:bg-surface-900 text-surface-900 dark:text-white transition-colors text-sm"
              >
                <option value="">{t(lang, "contact.form.service.placeholder")}</option>
                <option value="web-development">{t(lang, "contact.form.service.web")}</option>
                <option value="mobile-app">{t(lang, "contact.form.service.mobile")}</option>
                <option value="ui-ux-design">{t(lang, "contact.form.service.uiux")}</option>
                <option value="cloud-devops">{t(lang, "contact.form.service.cloud")}</option>
                <option value="other">{t(lang, "contact.form.service.other")}</option>
              </select>
            </div>

            <div>
              <label for="budget" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-2">
                {t(lang, "contact.form.budget")}
              </label>
              <select
                id="budget"
                name="budget"
                class="w-full px-4 py-3 border border-surface-200 dark:border-surface-600 rounded-xl bg-surface-50 dark:bg-surface-900 text-surface-900 dark:text-white transition-colors text-sm"
              >
                <option value="">{t(lang, "contact.form.budget.placeholder")}</option>
                <option value="5k-10k">$5,000 - $10,000</option>
                <option value="10k-25k">$10,000 - $25,000</option>
                <option value="25k-50k">$25,000 - $50,000</option>
                <option value="50k-100k">$50,000 - $100,000</option>
                <option value="100k+">$100,000+</option>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-2">
              {t(lang, "contact.form.message")} *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              class="w-full px-4 py-3 border border-surface-200 dark:border-surface-600 rounded-xl bg-surface-50 dark:bg-surface-900 text-surface-900 dark:text-white placeholder-surface-400 transition-colors text-sm resize-vertical"
              placeholder={t(lang, "contact.form.message.placeholder")}
            ></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input
              type="checkbox"
              id="privacy"
              name="privacy"
              required
              class="mt-0.5 h-4 w-4 text-brand-600 border-surface-300 rounded"
            />
            <label for="privacy" class="text-sm text-surface-600 dark:text-surface-400">
              {t(lang, "contact.form.privacy")} <a href="#" class="text-brand-600 dark:text-brand-400 hover:underline">{t(lang, "contact.form.privacyPolicy")}</a> {t(lang, "contact.form.and")} <a href="#" class="text-brand-600 dark:text-brand-400 hover:underline">{t(lang, "contact.form.terms")}</a>
            </label>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-700 hover:to-brand-600 text-white font-bold py-4 px-6 rounded-xl shadow-lg shadow-brand-500/30 hover:shadow-xl hover:shadow-brand-500/40 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed text-base hover:-translate-y-0.5"
          >
            <span id="btn-text">{t(lang, "contact.form.submit")}</span>
            <span id="btn-loading" class="hidden">
              <svg class="inline w-4 h-4 mr-2 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12a8 8 0 018-8V0a12 12 0 00-12 12h4zm8 8a8 8 0 01-8-8H0a12 12 0 0012 12v-4z" />
              </svg>
              {t(lang, "contact.form.sending")}
            </span>
          </button>
        </form>

        <!-- Success Message -->
        <div id="success-message" class="hidden mt-5 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-600 dark:text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <p class="text-green-800 dark:text-green-200 text-sm font-medium">{t(lang, "contact.form.success")}</p>
          </div>
        </div>

        <!-- Error Message -->
        <div id="error-message" class="hidden mt-5 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-600 dark:text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <p class="text-red-800 dark:text-red-200 text-sm font-medium">{t(lang, "contact.form.error")}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text");
  const btnLoading = document.getElementById("btn-loading");
  const successMessage = document.getElementById("success-message");
  const errorMessage = document.getElementById("error-message");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (submitBtn) submitBtn.disabled = true;
    btnText?.classList.add("hidden");
    btnLoading?.classList.remove("hidden");
    successMessage?.classList.add("hidden");
    errorMessage?.classList.add("hidden");

    try {
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      console.log("Sending data to API:", data);

      const response = await fetch("/api/contact", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      if (!response.ok) throw new Error("Submission failed");

      successMessage?.classList.remove("hidden");
      form?.reset();
    } catch (error) {
      console.error("Form submission error:", error);
      errorMessage?.classList.remove("hidden");
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      btnText?.classList.remove("hidden");
      btnLoading?.classList.add("hidden");
    }
  });
</script>
