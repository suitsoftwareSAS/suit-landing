---
import { t, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
---

<section id="home" class="pt-16 min-h-screen flex items-center bg-gradient-to-br from-white via-brand-50/30 to-accent-500/5 dark:from-surface-950 dark:via-brand-900/10 dark:to-surface-950 relative overflow-hidden">
  <!-- Animated gradient orbs -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-500/20 dark:bg-brand-600/20 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-3xl opacity-70 animate-blob"></div>
  <div class="absolute top-0 right-1/4 w-96 h-96 bg-accent-500/20 dark:bg-accent-500/10 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-3xl opacity-70 animate-blob animation-delay-2000"></div>
  <div class="absolute -bottom-32 left-1/3 w-96 h-96 bg-brand-400/20 dark:bg-brand-700/20 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-3xl opacity-70 animate-blob animation-delay-4000"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32 relative z-10 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div class="flex flex-col gap-8">
        <!-- Tagline with animated gradient badge -->
        <div class="reveal-on-scroll">
          <span class="inline-flex items-center gap-2 px-4 py-2 text-xs font-semibold tracking-wide rounded-full bg-gradient-to-r from-brand-100 to-accent-100 dark:from-brand-900/50 dark:to-accent-900/30 text-brand-700 dark:text-brand-300 border border-brand-200/50 dark:border-brand-700/50 shadow-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
            </span>
            {t(lang, "hero.tagline")}
          </span>
        </div>

        <!-- Heading with gradient text -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black tracking-tight leading-[1.1] reveal-on-scroll reveal-delay-1">
          <span class="text-surface-900 dark:text-white font-sans">{t(lang, "hero.title.line1")}</span>
          <br />
          <span class="text-gradient bg-gradient-to-r from-brand-600 via-brand-500 to-brand-400 dark:from-brand-400 dark:via-brand-300 dark:to-brand-200 bg-clip-text text-transparent font-sans">
            {t(lang, "hero.title.highlight")}
          </span>
          <br />
          <span class="text-surface-900 dark:text-white font-sans">{t(lang, "hero.title.line2")}</span>
        </h1>

        <!-- Description -->
        <p class="text-lg sm:text-xl leading-relaxed text-surface-600 dark:text-surface-300 max-w-xl reveal-on-scroll reveal-delay-2">
          {t(lang, "hero.description")}
        </p>

        <!-- CTA Buttons with modern styling -->
        <div class="flex flex-col sm:flex-row gap-4 reveal-on-scroll reveal-delay-3">
          <a
            href="#contact"
            class="group inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white bg-gradient-to-r from-accent-600 to-accent-500 hover:from-accent-700 hover:to-accent-600 rounded-xl shadow-lg shadow-accent-500/30 transition-all duration-200 hover:shadow-xl hover:shadow-accent-500/40 hover:-translate-y-0.5 cursor-pointer"
          >
            {t(lang, "hero.cta.primary")}
            <svg class="ml-2 w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a
            href="#services"
            class="group inline-flex items-center justify-center px-8 py-4 text-base font-bold text-brand-700 dark:text-brand-300 bg-white dark:bg-surface-800 hover:bg-brand-50 dark:hover:bg-surface-700 border-2 border-brand-200 dark:border-brand-700 rounded-xl transition-all duration-200 hover:-translate-y-0.5 cursor-pointer"
          >
            {t(lang, "hero.cta.secondary")}
            <svg class="ml-2 w-5 h-5 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
        </div>

        <!-- Stats with modern card design -->
        <div class="grid grid-cols-3 gap-4 pt-8 reveal-on-scroll reveal-delay-4">
          <div class="bg-white/60 dark:bg-surface-800/60 backdrop-blur-sm rounded-2xl p-4 border border-surface-200/50 dark:border-surface-700/50">
            <div class="text-2xl sm:text-3xl font-black text-brand-600 dark:text-brand-400 font-sans">50+</div>
            <div class="text-xs sm:text-sm text-surface-600 dark:text-surface-400 mt-1">{t(lang, "hero.stat.projects")}</div>
          </div>
          <div class="bg-white/60 dark:bg-surface-800/60 backdrop-blur-sm rounded-2xl p-4 border border-surface-200/50 dark:border-surface-700/50">
            <div class="text-2xl sm:text-3xl font-black text-brand-600 dark:text-brand-400 font-sans">98%</div>
            <div class="text-xs sm:text-sm text-surface-600 dark:text-surface-400 mt-1">{t(lang, "hero.stat.satisfaction")}</div>
          </div>
          <div class="bg-white/60 dark:bg-surface-800/60 backdrop-blur-sm rounded-2xl p-4 border border-surface-200/50 dark:border-surface-700/50">
            <div class="text-2xl sm:text-3xl font-black text-brand-600 dark:text-brand-400 font-sans">24/7</div>
            <div class="text-xs sm:text-sm text-surface-600 dark:text-surface-400 mt-1">{t(lang, "hero.stat.support")}</div>
          </div>
        </div>
      </div>

      <!-- Hero Visual - Modern Stack Visualization -->
      <div class="hidden lg:flex items-center justify-center relative reveal-on-scroll reveal-right reveal-delay-2">
        <div class="relative w-full max-w-md">
          <!-- Main code editor card -->
          <div class="glass bg-white/80 dark:bg-surface-900/80 border border-surface-200/50 dark:border-surface-700/50 rounded-2xl p-8 relative z-10 shadow-2xl shadow-brand-900/10 dark:shadow-brand-400/5 transition-transform duration-500 hover:scale-[1.02]">
            <!-- Editor header -->
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <div class="text-xs text-surface-500 dark:text-surface-400 font-mono">index.ts</div>
            </div>
            
            <!-- Modern code snippet -->
            <div class="font-mono text-sm space-y-3 text-left">
              <div class="flex gap-2">
                <span class="text-brand-500 font-semibold">const</span>
                <span class="text-accent-600 dark:text-accent-400">solution</span>
                <span class="text-surface-400">=</span>
                <span class="text-surface-500">{'{'}</span>
              </div>
              <div class="pl-6 flex gap-2">
                <span class="text-brand-400">innovation</span><span class="text-surface-400">:</span>
                <span class="text-emerald-600 dark:text-emerald-400">"cutting-edge"</span><span class="text-surface-400">,</span>
              </div>
              <div class="pl-6 flex gap-2">
                <span class="text-brand-400">quality</span><span class="text-surface-400">:</span>
                <span class="text-emerald-600 dark:text-emerald-400">"exceptional"</span><span class="text-surface-400">,</span>
              </div>
              <div class="pl-6 flex gap-2">
                <span class="text-brand-400">delivery</span><span class="text-surface-400">:</span>
                <span class="text-emerald-600 dark:text-emerald-400">"on-time"</span><span class="text-surface-400">,</span>
              </div>
              <div class="pl-6 flex gap-2">
                <span class="text-brand-400">support</span><span class="text-surface-400">:</span>
                <span class="text-emerald-600 dark:text-emerald-400">"24/7"</span>
              </div>
              <div class="flex gap-2">
                <span class="text-surface-500">{'}'}</span><span class="text-surface-400">;</span>
              </div>
            </div>

            <!-- Animated cursor -->
            <div class="mt-4 flex items-center">
              <span class="text-surface-400 font-mono text-sm">|</span>
              <span class="inline-block w-2 h-4 bg-brand-500 ml-0.5 animate-pulse"></span>
            </div>
          </div>

          <!-- Floating status badges -->
          <div class="absolute -top-6 -right-6 bg-gradient-to-br from-accent-500 to-accent-600 text-white rounded-2xl px-5 py-3 shadow-lg shadow-accent-500/40 z-20 animate-float">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="font-bold text-sm">Build Successful</span>
            </div>
          </div>

          <div class="absolute -bottom-6 -left-6 glass bg-white/90 dark:bg-surface-800/90 border border-surface-200/50 dark:border-surface-700/50 rounded-2xl px-5 py-4 shadow-xl z-20 animate-float-delayed">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-gradient-to-br from-brand-500 to-brand-600 rounded-xl flex items-center justify-center shadow-lg">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-500 dark:text-surface-400">Performance</div>
                <div class="text-base font-black text-surface-900 dark:text-white font-sans">99.9% Uptime</div>
              </div>
            </div>
          </div>

          <!-- Tech stack pills -->
          <div class="absolute -right-8 top-1/3 flex flex-col gap-2 z-15 animate-float-slow">
            <div class="bg-blue-500/10 border border-blue-500/30 text-blue-700 dark:text-blue-300 px-3 py-1.5 rounded-full text-xs font-bold backdrop-blur-sm">React</div>
            <div class="bg-green-500/10 border border-green-500/30 text-green-700 dark:text-green-300 px-3 py-1.5 rounded-full text-xs font-bold backdrop-blur-sm">Node.js</div>
            <div class="bg-purple-500/10 border border-purple-500/30 text-purple-700 dark:text-purple-300 px-3 py-1.5 rounded-full text-xs font-bold backdrop-blur-sm">AWS</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(1deg); }
  }
  
  @keyframes float-delayed {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(-1deg); }
  }
  
  @keyframes float-slow {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(-8px); }
  }
  
  @keyframes blob {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-float-delayed {
    animation: float-delayed 7s ease-in-out infinite 1s;
  }
  
  .animate-float-slow {
    animation: float-slow 8s ease-in-out infinite 0.5s;
  }
  
  .animate-blob {
    animation: blob 10s infinite;
  }
  
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
