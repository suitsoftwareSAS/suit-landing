---
import { t, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
---

<section id="home" class="pt-16 min-h-screen flex items-center bg-white dark:bg-surface-950 relative overflow-hidden">
  <!-- Subtle background pattern -->
  <div class="absolute inset-0 opacity-[0.02] dark:opacity-[0.05]" style="background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0); background-size: 40px 40px;"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32 relative z-10 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div class="flex flex-col gap-8">
        <!-- Tagline -->
        <div class="reveal-on-scroll">
          <span class="inline-flex items-center px-3 py-1 text-xs font-semibold tracking-wider uppercase rounded-full bg-brand-50 dark:bg-brand-900/30 text-brand-700 dark:text-brand-300 border border-brand-200 dark:border-brand-800">
            {t(lang, "hero.tagline")}
          </span>
        </div>

        <!-- Heading -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-surface-900 dark:text-white leading-[1.1] reveal-on-scroll reveal-delay-1">
          <span class="text-balance">{t(lang, "hero.title.line1")}</span>
          <br />
          <span class="text-brand-600 dark:text-brand-400">{t(lang, "hero.title.highlight")}</span>
          <br />
          <span class="text-balance">{t(lang, "hero.title.line2")}</span>
        </h1>

        <!-- Description -->
        <p class="text-lg leading-relaxed text-surface-600 dark:text-surface-400 max-w-xl reveal-on-scroll reveal-delay-2">
          {t(lang, "hero.description")}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 reveal-on-scroll reveal-delay-3">
          <a
            href="#contact"
            class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-brand-900 hover:bg-brand-800 dark:bg-brand-600 dark:hover:bg-brand-500 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-brand-900/25 dark:hover:shadow-brand-600/25 hover:-translate-y-0.5"
          >
            {t(lang, "hero.cta.primary")}
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a
            href="#services"
            class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-surface-700 dark:text-surface-300 bg-surface-100 dark:bg-surface-800 hover:bg-surface-200 dark:hover:bg-surface-700 rounded-xl transition-all duration-300 hover:-translate-y-0.5"
          >
            {t(lang, "hero.cta.secondary")}
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 pt-8 border-t border-surface-200 dark:border-surface-800 reveal-on-scroll reveal-delay-4">
          <div>
            <div class="text-2xl sm:text-3xl font-extrabold text-brand-900 dark:text-brand-400">50+</div>
            <div class="text-sm text-surface-500 dark:text-surface-500 mt-1">{t(lang, "hero.stat.projects")}</div>
          </div>
          <div>
            <div class="text-2xl sm:text-3xl font-extrabold text-brand-900 dark:text-brand-400">98%</div>
            <div class="text-sm text-surface-500 dark:text-surface-500 mt-1">{t(lang, "hero.stat.satisfaction")}</div>
          </div>
          <div>
            <div class="text-2xl sm:text-3xl font-extrabold text-brand-900 dark:text-brand-400">24/7</div>
            <div class="text-sm text-surface-500 dark:text-surface-500 mt-1">{t(lang, "hero.stat.support")}</div>
          </div>
        </div>
      </div>

      <!-- Hero Visual -->
      <div class="hidden lg:flex items-center justify-center relative reveal-on-scroll reveal-right reveal-delay-2">
        <div class="relative w-full max-w-md">
          <!-- Main card -->
          <div class="bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl p-8 relative z-10 transition-transform duration-500 hover:scale-[1.02]">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <!-- Code snippet aesthetic -->
            <div class="font-mono text-sm space-y-3">
              <div class="flex gap-2">
                <span class="text-brand-500">const</span>
                <span class="text-accent-500">project</span>
                <span class="text-surface-400">=</span>
                <span class="text-surface-500">{'{'}</span>
              </div>
              <div class="pl-6 flex gap-2">
                <span class="text-brand-400">quality</span><span class="text-surface-400">:</span>
                <span class="text-green-500">"exceptional"</span><span class="text-surface-400">,</span>
              </div>
              <div class="pl-6 flex gap-2">
                <span class="text-brand-400">delivery</span><span class="text-surface-400">:</span>
                <span class="text-green-500">"on-time"</span><span class="text-surface-400">,</span>
              </div>
              <div class="pl-6 flex gap-2">
                <span class="text-brand-400">support</span><span class="text-surface-400">:</span>
                <span class="text-green-500">"24/7"</span>
              </div>
              <div>
                <span class="text-surface-500">{'}'}</span><span class="text-surface-400">;</span>
              </div>
            </div>
          </div>

          <!-- Floating accent cards -->
          <div class="absolute -top-4 -right-4 bg-brand-900 dark:bg-brand-600 text-white rounded-xl px-4 py-2 text-sm font-semibold shadow-lg z-20 animate-float">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Deploy Success
            </div>
          </div>

          <div class="absolute -bottom-4 -left-4 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-xl px-4 py-3 shadow-lg z-20 animate-float-delayed">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-accent-500/10 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-500">Performance</div>
                <div class="text-sm font-bold text-surface-900 dark:text-white">99.9% Uptime</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  @keyframes float-delayed {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
  .animate-float-delayed {
    animation: float-delayed 5s ease-in-out infinite 1s;
  }
</style>
