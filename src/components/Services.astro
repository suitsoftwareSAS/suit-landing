---
import { t, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const services = [
  {
    titleKey: "services.web.title",
    descKey: "services.web.description",
    items: ["services.web.item1", "services.web.item2", "services.web.item3"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`,
  },
  {
    titleKey: "services.mobile.title",
    descKey: "services.mobile.description",
    items: ["services.mobile.item1", "services.mobile.item2", "services.mobile.item3"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
  },
  {
    titleKey: "services.uiux.title",
    descKey: "services.uiux.description",
    items: ["services.uiux.item1", "services.uiux.item2", "services.uiux.item3"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zm12 0a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />`,
  },
  {
    titleKey: "services.cloud.title",
    descKey: "services.cloud.description",
    items: ["services.cloud.item1", "services.cloud.item2", "services.cloud.item3"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />`,
  },
];

const processSteps = [
  { titleKey: "process.step1.title", descKey: "process.step1.description" },
  { titleKey: "process.step2.title", descKey: "process.step2.description" },
  { titleKey: "process.step3.title", descKey: "process.step3.description" },
  { titleKey: "process.step4.title", descKey: "process.step4.description" },
];
---

<section id="services" class="py-24 bg-surface-50 dark:bg-surface-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 reveal-on-scroll">
      <span class="text-sm font-semibold tracking-wider uppercase text-brand-600 dark:text-brand-400">
        {t(lang, "services.label")}
      </span>
      <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-surface-900 dark:text-white text-balance">
        {t(lang, "services.title")}
      </h2>
      <p class="mt-4 text-lg text-surface-600 dark:text-surface-400 leading-relaxed">
        {t(lang, "services.description")}
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-2 gap-6">
      {services.map((service, index) => (
        <div class:list={[
          "group relative bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-2xl p-8 hover:border-brand-300 dark:hover:border-brand-700 transition-all duration-300 hover:shadow-lg hover:shadow-brand-900/5 dark:hover:shadow-brand-400/5 hover:-translate-y-1 reveal-on-scroll",
          `reveal-delay-${index + 1}`
        ]}>
          <!-- Icon -->
          <div class="w-12 h-12 bg-brand-50 dark:bg-brand-900/30 rounded-xl flex items-center justify-center mb-6 group-hover:bg-brand-100 dark:group-hover:bg-brand-900/50 transition-colors duration-300">
            <svg class="w-6 h-6 text-brand-600 dark:text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={service.icon} />
            </svg>
          </div>

          <h3 class="text-xl font-bold text-surface-900 dark:text-white mb-3">
            {t(lang, service.titleKey)}
          </h3>

          <p class="text-surface-600 dark:text-surface-400 mb-6 leading-relaxed">
            {t(lang, service.descKey)}
          </p>

          <ul class="flex flex-col gap-2.5">
            {service.items.map((itemKey) => (
              <li class="flex items-center gap-2.5 text-sm text-surface-600 dark:text-surface-400">
                <svg class="w-4 h-4 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {t(lang, itemKey)}
              </li>
            ))}
          </ul>

          <!-- Hover arrow -->
          <div class="absolute top-8 right-8 opacity-0 group-hover:opacity-100 transition-all duration-300 group-hover:translate-x-1 group-hover:-translate-y-1">
            <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </div>
        </div>
      ))}
    </div>

    <!-- Process Section -->
    <div class="mt-24">
      <div class="max-w-3xl mb-12 reveal-on-scroll">
        <h3 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-surface-900 dark:text-white">
          {t(lang, "process.title")}
        </h3>
        <p class="mt-3 text-lg text-surface-600 dark:text-surface-400">
          {t(lang, "process.description")}
        </p>
      </div>

      <div class="grid md:grid-cols-4 gap-8">
        {processSteps.map((step, index) => (
          <div class:list={["relative reveal-on-scroll", `reveal-delay-${index + 1}`]}>
            {index < processSteps.length - 1 && (
              <div class="hidden md:block absolute top-6 left-[calc(50%+24px)] w-[calc(100%-48px)] h-px bg-surface-200 dark:bg-surface-700"></div>
            )}
            <div class="flex flex-col items-center text-center md:items-start md:text-left">
              <div class="w-12 h-12 bg-brand-900 dark:bg-brand-600 text-white rounded-xl flex items-center justify-center mb-4 text-lg font-bold relative z-10 transition-transform duration-300 hover:scale-110">
                {index + 1}
              </div>
              <h4 class="text-lg font-bold text-surface-900 dark:text-white mb-2">
                {t(lang, step.titleKey)}
              </h4>
              <p class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed">
                {t(lang, step.descKey)}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
