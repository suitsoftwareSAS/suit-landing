---
import { t, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const services = [
  {
    titleKey: "services.web.title",
    descKey: "services.web.description",
    items: ["services.web.item1", "services.web.item2", "services.web.item3"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`,
  },
  {
    titleKey: "services.mobile.title",
    descKey: "services.mobile.description",
    items: ["services.mobile.item1", "services.mobile.item2", "services.mobile.item3"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
  },
  {
    titleKey: "services.uiux.title",
    descKey: "services.uiux.description",
    items: ["services.uiux.item1", "services.uiux.item2", "services.uiux.item3"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zm12 0a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />`,
  },
  {
    titleKey: "services.cloud.title",
    descKey: "services.cloud.description",
    items: ["services.cloud.item1", "services.cloud.item2", "services.cloud.item3"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />`,
  },
];

const processSteps = [
  { titleKey: "process.step1.title", descKey: "process.step1.description" },
  { titleKey: "process.step2.title", descKey: "process.step2.description" },
  { titleKey: "process.step3.title", descKey: "process.step3.description" },
  { titleKey: "process.step4.title", descKey: "process.step4.description" },
];
---

<section id="services" class="py-24 lg:py-32 bg-white dark:bg-surface-950 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-500/5 dark:bg-brand-600/5 rounded-full filter blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-accent-500/5 dark:bg-accent-500/5 rounded-full filter blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="max-w-3xl mx-auto text-center mb-16 reveal-on-scroll">
      <span class="inline-flex items-center gap-2 px-4 py-2 text-xs font-bold tracking-wide uppercase rounded-full bg-brand-100 dark:bg-brand-900/30 text-brand-700 dark:text-brand-400 border border-brand-200 dark:border-brand-800 mb-4">
        {t(lang, "services.label")}
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-black tracking-tight text-surface-900 dark:text-white text-balance font-sans">
        {t(lang, "services.title")}
      </h2>
      <p class="mt-6 text-lg sm:text-xl text-surface-600 dark:text-surface-300 leading-relaxed">
        {t(lang, "services.description")}
      </p>
    </div>

    <!-- Services Grid - Modern Cards -->
    <div class="grid md:grid-cols-2 gap-8 lg:gap-10">
      {services.map((service, index) => (
        <div class:list={[
          "group relative bg-gradient-to-br from-white to-surface-50/50 dark:from-surface-800 dark:to-surface-900/50 border-2 border-surface-200 dark:border-surface-700 rounded-3xl p-8 lg:p-10 hover:border-brand-400 dark:hover:border-brand-600 transition-all duration-300 hover:shadow-2xl hover:shadow-brand-900/10 dark:hover:shadow-brand-400/10 hover:-translate-y-2 reveal-on-scroll card-interactive cursor-pointer",
          `reveal-delay-${index + 1}`
        ]}>
          <!-- Icon with gradient background -->
          <div class="relative mb-6">
            <div class="absolute inset-0 bg-gradient-to-br from-brand-500 to-accent-500 rounded-2xl opacity-10 group-hover:opacity-20 transition-opacity"></div>
            <div class="relative w-16 h-16 bg-gradient-to-br from-brand-100 to-brand-50 dark:from-brand-900/40 dark:to-brand-800/40 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-brand-600 dark:text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <Fragment set:html={service.icon} />
              </svg>
            </div>
          </div>

          <h3 class="text-2xl lg:text-3xl font-black text-surface-900 dark:text-white mb-4 font-sans group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
            {t(lang, service.titleKey)}
          </h3>

          <p class="text-base lg:text-lg text-surface-600 dark:text-surface-300 mb-6 leading-relaxed">
            {t(lang, service.descKey)}
          </p>

          <ul class="flex flex-col gap-3">
            {service.items.map((itemKey) => (
              <li class="flex items-start gap-3 text-sm lg:text-base text-surface-700 dark:text-surface-300">
                <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{t(lang, itemKey)}</span>
              </li>
            ))}
          </ul>

          <!-- Animated corner accent -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-brand-500/10 to-transparent dark:from-brand-400/10 rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      ))}
    </div>

    <!-- Process Section - Modern Timeline -->
    <div class="mt-32">
      <div class="max-w-3xl mx-auto text-center mb-16 reveal-on-scroll">
        <h3 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-surface-900 dark:text-white font-sans">
          {t(lang, "process.title")}
        </h3>
        <p class="mt-6 text-lg sm:text-xl text-surface-600 dark:text-surface-300 leading-relaxed">
          {t(lang, "process.description")}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
        {processSteps.map((step, index) => (
          <div class:list={["relative reveal-on-scroll", `reveal-delay-${index + 1}`]}>
            {/* Connecting line */}
            {index < processSteps.length - 1 && (
              <div class="hidden lg:block absolute top-10 left-[calc(50%+40px)] w-[calc(100%-80px)] h-0.5 bg-gradient-to-r from-brand-300 via-brand-200 to-transparent dark:from-brand-700 dark:via-brand-800 dark:to-transparent"></div>
            )}
            
            <div class="flex flex-col items-center text-center group cursor-pointer">
              {/* Step number with gradient */}
              <div class="relative mb-6">
                <div class="absolute inset-0 bg-gradient-to-br from-brand-500 to-accent-500 rounded-2xl blur-lg opacity-20 group-hover:opacity-40 transition-opacity"></div>
                <div class="relative w-20 h-20 bg-gradient-to-br from-brand-600 to-brand-500 dark:from-brand-500 dark:to-brand-600 text-white rounded-2xl flex items-center justify-center text-2xl font-black shadow-lg shadow-brand-500/30 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 z-10">
                  {index + 1}
                </div>
              </div>
              
              <h4 class="text-xl lg:text-2xl font-black text-surface-900 dark:text-white mb-3 font-sans group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                {t(lang, step.titleKey)}
              </h4>
              
              <p class="text-sm lg:text-base text-surface-600 dark:text-surface-400 leading-relaxed">
                {t(lang, step.descKey)}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
