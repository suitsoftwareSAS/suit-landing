---
import { t, type Lang } from "../i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const testimonials = [
  {
    quoteKey: "testimonial.1.quote",
    nameKey: "testimonial.1.name",
    roleKey: "testimonial.1.role",
    initials: "JS",
  },
  {
    quoteKey: "testimonial.2.quote",
    nameKey: "testimonial.2.name",
    roleKey: "testimonial.2.role",
    initials: "MJ",
  },
  {
    quoteKey: "testimonial.3.quote",
    nameKey: "testimonial.3.name",
    roleKey: "testimonial.3.role",
    initials: "DW",
  },
];
---

<section id="clients" class="py-24 bg-white dark:bg-surface-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal-on-scroll">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-surface-900 dark:text-white text-balance">
        {t(lang, "clients.title")}
      </h2>
      <p class="mt-4 text-lg text-surface-600 dark:text-surface-400 leading-relaxed">
        {t(lang, "clients.description")}
      </p>
    </div>

    <!-- Client Logos -->
    <div class="grid grid-cols-3 md:grid-cols-6 gap-6 mb-20">
      {["TECH CO", "STARTUP", "FINTECH", "E-COMM", "HEALTH", "SAAS"].map((name, index) => (
        <div class:list={[
          "flex items-center justify-center p-6 bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-xl hover:border-brand-300 dark:hover:border-brand-700 transition-all duration-300 hover:shadow-md hover:-translate-y-0.5 reveal-on-scroll reveal-scale",
          index < 3 ? `reveal-delay-${index + 1}` : `reveal-delay-${index - 2}`
        ]}>
          <span class="text-sm font-bold text-surface-400 dark:text-surface-600 tracking-wider">{name}</span>
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <div class="mb-16">
      <h3 class="text-2xl sm:text-3xl font-extrabold text-center text-surface-900 dark:text-white mb-12 reveal-on-scroll">
        {t(lang, "clients.testimonials.title")}
      </h3>

      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map((testimonial, index) => (
          <div class:list={[
            "bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl p-8 flex flex-col transition-all duration-300 hover:shadow-lg hover:border-brand-300 dark:hover:border-brand-700 hover:-translate-y-1 reveal-on-scroll",
            `reveal-delay-${index + 1}`
          ]}>
            <!-- Stars -->
            <div class="flex gap-0.5 mb-6">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <blockquote class="text-surface-600 dark:text-surface-400 leading-relaxed flex-1 mb-6">
              "{t(lang, testimonial.quoteKey)}"
            </blockquote>

            <div class="flex items-center gap-3 pt-6 border-t border-surface-200 dark:border-surface-800">
              <div class="w-10 h-10 bg-brand-900 dark:bg-brand-600 rounded-full flex items-center justify-center">
                <span class="text-white text-sm font-bold">{testimonial.initials}</span>
              </div>
              <div>
                <div class="font-semibold text-surface-900 dark:text-white text-sm">
                  {t(lang, testimonial.nameKey)}
                </div>
                <div class="text-xs text-surface-500">
                  {t(lang, testimonial.roleKey)}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center bg-brand-900 dark:bg-brand-800 rounded-2xl p-12 reveal-on-scroll reveal-scale">
      <h3 class="text-2xl font-bold text-white mb-3 text-balance">
        {t(lang, "clients.cta.title")}
      </h3>
      <p class="text-brand-200 mb-8 max-w-2xl mx-auto leading-relaxed">
        {t(lang, "clients.cta.description")}
      </p>
      <a
        href="#contact"
        class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-brand-900 bg-white hover:bg-brand-50 rounded-xl transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
      >
        {t(lang, "clients.cta.button")}
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
