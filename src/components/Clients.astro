---
import { t, type Lang } from "../i18n/translations";
import { Gallery4 } from "../components/ui/gallery4";
import type { Gallery4Item } from "../components/ui/gallery4";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const testimonials = [
  {
    quoteKey: "testimonial.1.quote",
    nameKey: "testimonial.1.name",
    roleKey: "testimonial.1.role",
    initials: "JS",
  },
  {
    quoteKey: "testimonial.2.quote",
    nameKey: "testimonial.2.name",
    roleKey: "testimonial.2.role",
    initials: "MJ",
  },
  {
    quoteKey: "testimonial.3.quote",
    nameKey: "testimonial.3.name",
    roleKey: "testimonial.3.role",
    initials: "DW",
  },
];

const caseStudies: Gallery4Item[] = [
  {
    id: "tech-co",
    title: t(lang, "caseStudies.techco.title"),
    description: t(lang, "caseStudies.techco.description"),
    href: "#contact",
    image: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1080&q=80",
  },
  {
    id: "startup",
    title: t(lang, "caseStudies.startup.title"),
    description: t(lang, "caseStudies.startup.description"),
    href: "#contact",
    image: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1080&q=80",
  },
  {
    id: "fintech",
    title: t(lang, "caseStudies.fintech.title"),
    description: t(lang, "caseStudies.fintech.description"),
    href: "#contact",
    image: "https://images.unsplash.com/photo-1559526324-4b87b5e36e44?w=1080&q=80",
  },
  {
    id: "ecommerce",
    title: t(lang, "caseStudies.ecommerce.title"),
    description: t(lang, "caseStudies.ecommerce.description"),
    href: "#contact",
    image: "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1080&q=80",
  },
  {
    id: "health",
    title: t(lang, "caseStudies.health.title"),
    description: t(lang, "caseStudies.health.description"),
    href: "#contact",
    image: "https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=1080&q=80",
  },
  {
    id: "saas",
    title: t(lang, "caseStudies.saas.title"),
    description: t(lang, "caseStudies.saas.description"),
    href: "#contact",
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=1080&q=80",
  },
];
---

<section id="clients" class="py-24 lg:py-32 bg-surface-50 dark:bg-surface-900 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-500/5 dark:bg-brand-600/5 rounded-full filter blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal-on-scroll">
      <span class="inline-flex items-center gap-2 px-4 py-2 text-xs font-bold tracking-wide uppercase rounded-full bg-brand-100 dark:bg-brand-900/30 text-brand-700 dark:text-brand-400 border border-brand-200 dark:border-brand-800 mb-4">
        {t(lang, "clients.label")}
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-black tracking-tight text-surface-900 dark:text-white text-balance font-sans">
        {t(lang, "clients.title")}
      </h2>
      <p class="mt-6 text-lg sm:text-xl text-surface-600 dark:text-surface-300 leading-relaxed">
        {t(lang, "clients.description")}
      </p>
    </div>

    <!-- Case Studies Gallery -->
    <div class="mb-20">
      <Gallery4
        client:visible
        title={t(lang, "caseStudies.title")}
        description={t(lang, "caseStudies.description")}
        readMore={t(lang, "caseStudies.readMore")}
        items={caseStudies}
      />
    </div>

    <!-- Testimonials -->
    <div class="mb-20">
      <h3 class="text-2xl sm:text-3xl lg:text-4xl font-black text-center text-surface-900 dark:text-white mb-12 reveal-on-scroll font-sans">
        {t(lang, "clients.testimonials.title")}
      </h3>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        {testimonials.map((testimonial, index) => (
          <div class:list={[
            "bg-white dark:bg-surface-800 border-2 border-surface-200 dark:border-surface-700 rounded-3xl p-8 lg:p-10 flex flex-col transition-all duration-300 hover:shadow-2xl hover:border-brand-400 dark:hover:border-brand-600 hover:-translate-y-2 reveal-on-scroll",
            `reveal-delay-${index + 1}`
          ]}>
            <!-- Stars -->
            <div class="flex gap-0.5 mb-6">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <blockquote class="text-surface-600 dark:text-surface-400 leading-relaxed flex-1 mb-6">
              "{t(lang, testimonial.quoteKey)}"
            </blockquote>

            <div class="flex items-center gap-3 pt-6 border-t-2 border-surface-200 dark:border-surface-700">
              <div class="w-12 h-12 bg-gradient-to-br from-brand-600 to-brand-500 dark:from-brand-500 dark:to-brand-600 rounded-xl flex items-center justify-center shadow-lg">
                <span class="text-white text-base font-black">{testimonial.initials}</span>
              </div>
              <div>
                <div class="font-semibold text-surface-900 dark:text-white text-sm">
                  {t(lang, testimonial.nameKey)}
                </div>
                <div class="text-xs text-surface-500">
                  {t(lang, testimonial.roleKey)}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center bg-brand-900 dark:bg-brand-800 rounded-2xl p-12 reveal-on-scroll reveal-scale">
      <h3 class="text-2xl font-bold text-white mb-3 text-balance">
        {t(lang, "clients.cta.title")}
      </h3>
      <p class="text-brand-200 mb-8 max-w-2xl mx-auto leading-relaxed">
        {t(lang, "clients.cta.description")}
      </p>
      <a
        href="#contact"
        class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-brand-900 bg-white hover:bg-brand-50 rounded-xl transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
      >
        {t(lang, "clients.cta.button")}
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
