---
import type { Lang } from "../i18n/translations";

export interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title = "Suit Software - Modern Software Solutions",
  description = "High-quality web development, mobile apps, UI/UX design, and cloud consulting services.",
  lang = "en",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Dark mode: prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem("theme");
        if (theme === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          // Default to dark mode if no preference is saved
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <!-- Analytics: dataLayer queue initialised immediately so no events are lost.
         Actual script loading is deferred until after window.load to remove
         ~251 KiB from the critical path (gtag.js + gtm.js). -->
    <script is:inline>
      // Initialise dataLayer queue and gtag stub immediately
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", "G-E2L1SJDEGV");

      // Queue the GTM start event so timing is accurate
      window.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });

      // Load both scripts after the page is fully loaded
      function loadAnalytics() {
        // GA4
        var gaScript = document.createElement("script");
        gaScript.async = true;
        gaScript.src = "https://www.googletagmanager.com/gtag/js?id=G-E2L1SJDEGV";
        document.head.appendChild(gaScript);

        // GTM
        var gtmScript = document.createElement("script");
        gtmScript.async = true;
        gtmScript.src = "https://www.googletagmanager.com/gtm.js?id=GTM-NC5CQP3Q";
        document.head.appendChild(gtmScript);
      }

      if (document.readyState === "complete") {
        loadAnalytics();
      } else {
        window.addEventListener("load", loadAnalytics);
      }
    </script>
    <link rel="icon" type="image/svg+xml" href="/logo-white.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="facebook-domain-verification"
      content="yi3ui9a15tyuw74cofv68ycq038r3w"
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Load Google Fonts asynchronously to avoid render-blocking -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700;800;900&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body class="font-body bg-white dark:bg-surface-950 text-surface-900 dark:text-surface-100 antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NC5CQP3Q"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <slot />

    <!-- Scroll reveal animation observer -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function() {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: "0px 0px -40px 0px" });

        document.querySelectorAll(".reveal-on-scroll").forEach(function(el) {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    width: 100%;
    min-height: 100vh;
    line-height: 1.6;
  }
</style>
